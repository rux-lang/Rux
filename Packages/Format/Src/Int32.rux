import Text::{ String, StringBuilder };

// The decimal text of an int32, widened to int64 for the digit loop.
func ToString(value: int32) -> String {
    let mut builder = StringBuilder::WithCapacity(12);
    WriteInt(@builder, value as int64);
    return builder.IntoString();
}

extend int32 : Stringable {
    func ToString(self) -> String {
        return ToString(*self);
    }
}
