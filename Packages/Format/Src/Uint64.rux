import Text::{ String, StringBuilder };

// The decimal text of a uint64, in a String the caller owns and frees. There
// is no sign to write, so the digits stand alone.
func ToString(value: uint64) -> String {
    let mut builder = StringBuilder::WithCapacity(20);
    WriteUint(@builder, value);
    return builder.IntoString();
}

extend uint64 : Stringable {
    func ToString(self) -> String {
        return ToString(*self);
    }
}
