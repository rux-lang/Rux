import Text::{ String, StringBuilder };

// The decimal text of an int16, widened to int64 for the digit loop.
func ToString(value: int16) -> String {
    var builder = StringBuilder::WithCapacity(8);
    WriteInt(@builder, value as int64);
    return builder.IntoString();
}

extend int16 : Stringable {
    func ToString(self) -> String {
        return ToString(*self);
    }
}
