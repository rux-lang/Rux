// Returns the inverse cotangent, in radians
// https://rux-lang.dev/api/math/arccot
func ArcCot(x: float64) -> float64 {
    let pio2 = 1.5707963267948966;
    if x != x {
        return x;
    }
    return pio2 - ArcTan(x);
}

// Returns the inverse cotangent, in radians
// https://rux-lang.dev/api/math/arccot
func ArcCot(x: float32) -> float32 {
    return ArcCot(x as float64) as float32;
}
