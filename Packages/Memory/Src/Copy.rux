import Rux::{ CurrentTarget, OperatingSystem };

when CurrentTarget.os == OperatingSystem::Windows {
    import Windows::RtlCopyMemory;
}

// Copies bytes from one block of memory to another
// https://rux-lang.dev/api/memory/copy
func Copy(dest: *opaque, src: *const opaque, length: uint) {
    when CurrentTarget.os == OperatingSystem::Windows {
        RtlCopyMemory(dest, src, length);
    } else {
        let destination = dest as *uint8;
        let source = src as *const uint8;
        var offset: uint = 0;
        while offset < length {
            *(destination + offset) = *(source + offset);
            offset++;
        }
    }
}
