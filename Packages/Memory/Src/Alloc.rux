when CurrentTarget.os == OperatingSystem::FreeBSD ||
     CurrentTarget.os == OperatingSystem::OpenBSD ||
     CurrentTarget.os == OperatingSystem::NetBSD ||
     CurrentTarget.os == OperatingSystem::DragonFlyBSD {
    import Bsd::{
        IsError,
        Mmap,
        MapAnonymous,
        MapPrivate,
        ProtectionRead,
        ProtectionWrite
    };

    // Allocates an uninitialized block of memory
    // https://rux-lang.dev/api/memory/alloc
    func Alloc(size: uint) -> *opaque {
        // Two machine words keep the returned address aligned to 16 bytes.
        const HeaderSize: uint = 16;
        let total = size + HeaderSize;
        if total < size {
            return null;
        }

        let mapping = Mmap(
            null,
            total,
            ProtectionRead | ProtectionWrite,
            MapPrivate | MapAnonymous,
            -1,
            0
        );
        if IsError(mapping) {
            return null;
        }

        let header = mapping as *uint;
        *header = size;
        return (header + 2) as *opaque;
    }
}
