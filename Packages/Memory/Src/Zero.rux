import Rux::{ #target };

when #target.os == .Windows {
    import Windows::RtlZeroMemory;
}

// Fills a block of memory with zero bytes
// https://rux-lang.dev/api/memory/zero
func Zero(ptr: *opaque, size: uint) {
    when #target.os == .Windows {
        RtlZeroMemory(ptr, size);
    } else {
        let bytes = ptr as *mut uint8;
        let mut offset: uint = 0;
        while offset < size {
            *(bytes + offset) = 0 as uint8;
            offset++;
        }
    }
}
