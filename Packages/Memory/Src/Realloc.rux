        }

        let copySize = oldSize < size ? oldSize : size;
        Copy(resized, ptr, copySize);
        Free(ptr);
        return resized;
    }
}

when CurrentTarget.os == OperatingSystem::FreeBSD ||
     CurrentTarget.os == OperatingSystem::OpenBSD ||
     CurrentTarget.os == OperatingSystem::NetBSD ||
     CurrentTarget.os == OperatingSystem::DragonFlyBSD {
    // Resizes a block of memory, preserving the bytes that still fit
    // https://rux-lang.dev/api/memory/realloc
    func Realloc(ptr: *opaque, size: uint) -> *opaque {
        if ptr == null {
            return Alloc(size);
        }
        if size == 0 {
            Free(ptr);
            return null;
        }

        let header = (ptr as *uint) - 2;
        let oldSize = *header;
        let resized = Alloc(size);
        if resized == null {
            return null;
        }

        let copySize = oldSize < size ? oldSize : size;
        Copy(resized, ptr, copySize);
        Free(ptr);
        return resized;
    }
}
