func Main() -> int {
    // Literals
    if true != true { return 1; }
    if false != false { return 2; }

    // Basic assignments
    let a: bool = true;
    if !a { return 3; }

    let b: bool8 = true;
    if !b { return 4; }

    let c: bool32 = true;
    if !c { return 5; }

    // Bool -> integer
    if ((true as int32) != 1) { return 6; }
    if ((false as int32) != 0) { return 7; }

    // Integer -> bool
    if !(1 as bool) { return 8; }
    if (0 as bool) { return 9; }

    // Bool size conversions
    let b8: bool8 = true;
    let b32 = b8 as bool32;

    if !b32 { return 10; }

    let b8Again = b32 as bool8;

    if !b8Again { return 11; }

    // Logical operators
    if (true && false) { return 12; }
    if !(true || false) { return 13; }
    if !(!false) { return 14; }

    // Bitwise operators
    let bt: bool32 = true;
    let bf: bool32 = false;

    if (bt & bf) { return 15; }
    if !(bt | bf) { return 16; }
    if !(bt ^ bf) { return 17; }
    if (~bt) { return 18; }

    // Equality
    if !(true == true) { return 19; }
    if !(true != false) { return 20; }

    // Bool -> uint64
    if ((true as uint64) != 1u64) { return 21; }
    if ((false as uint64) != 0u64) { return 22; }

    // bool8 truth table
    let tt8: bool8 = true & true;
    if !tt8 { return 23; }

    let tf8: bool8 = true & false;
    if tf8 { return 24; }

    let ft8: bool8 = false & true;
    if ft8 { return 25; }

    let ff8: bool8 = false & false;
    if ff8 { return 26; }

    // bool16 XOR self
    let self16: bool16 = true ^ true;
    if self16 { return 27; }

    // De Morgan
    let p: bool8 = true;
    let q: bool8 = false;

    if (!(p & q) != (!p | !q)) {
        return 28;
    }

    // mixed widths
    let m1: bool8 = (true as bool8) & (true as bool16);
    if !m1 { return 29; }

    let m2: bool32 = (true as bool32) | (false as bool8);
    if !m2 { return 30; }

    return 0;
}