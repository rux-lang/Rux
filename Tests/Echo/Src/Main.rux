// Stdin read + stdout write: exercises ReadFile and WriteFile thunks.
// Writes a fixed string after reading to verify stdin reading works.

@[Import(lib: "kernel32")]
extern func GetStdHandle(handle: int) -> int;

@[Import(lib: "kernel32")]
extern func ReadFile(handle: int, buffer: *char8, count: uint64, read: *uint64, overlapped: int) -> bool;

@[Import(lib: "kernel32")]
extern func WriteFile(handle: int, buffer: *char8, count: uint64, written: *uint64, overlapped: int) -> bool;

func Main() -> int {
    var inbuf: char8[4096];
    var read: uint64 = 0;

    let stdin = GetStdHandle(-10);
    let stdout = GetStdHandle(-11);
    let buf = inbuf.data;

    ReadFile(stdin, buf, 4096, &read, 0);
    let msg = c8"read stdin OK\n";
    WriteFile(stdout, msg.data, msg.length, null, 0);
    return 0;
}
