func Main() -> int {
	// int8
	let minI8 = -128i8;
	let maxI8 = 127i8;

	if minI8 != -128 { return 1; }
	if maxI8 != 127 { return 2; }
	if minI8 - 1 != 127 { return 3; }
	if maxI8 + 1 != -128 { return 4; }

	if ~0i8 != -1 { return 5; }
	if ~5i8 != -6 { return 6; }

	if ((-1i8 as uint8) != 255u8) { return 7; }
	if ((255u8 as int8) != -1i8) { return 8; }

	if (1i8 << 7) != -128 { return 9; }
	if (-128i8 >> 1) != -64 { return 10; }

	// uint8
	let minU8 = 0u8;
	let maxU8 = 255u8;

	if minU8 != 0 { return 11; }
	if maxU8 != 255 { return 12; }

	if minU8 - 1 != 255u8 { return 13; }
	if maxU8 + 1 != 0u8 { return 14; }

	if ~0u8 != 255u8 { return 15; }
	if ~255u8 != 0u8 { return 16; }

	if (1u8 << 7) != 128u8 { return 17; }
	if (255u8 >> 1) != 127u8 { return 18; }

	// int16
	let minI16 = -32768i16;
	let maxI16 = 32767i16;

	if minI16 != -32768 { return 19; }
	if maxI16 != 32767 { return 20; }

	if minI16 - 1 != 32767 { return 21; }
	if maxI16 + 1 != -32768 { return 22; }

	if ~0i16 != -1 { return 23; }
	if ~5i16 != -6 { return 24; }

	if ((-1i16 as uint16) != 65535u16) { return 25; }
	if ((65535u16 as int16) != -1i16) { return 26; }

	if (1i16 << 15) != -32768 { return 27; }
	if (-32768i16 >> 1) != -16384 { return 28; }

	// uint16
	if 0u16 - 1 != 65535u16 { return 29; }
	if 65535u16 + 1 != 0u16 { return 30; }

	if ~0u16 != 65535u16 { return 31; }
	if ~65535u16 != 0u16 { return 32; }

	if (1u16 << 15) != 32768u16 { return 33; }
	if (65535u16 >> 1) != 32767u16 { return 34; }

	// int32
	let minI32 = -2147483648i32;
	let maxI32 = 2147483647i32;

	if minI32 - 1 != 2147483647 { return 35; }
	if maxI32 + 1 != -2147483648 { return 36; }

	if ~0i32 != -1 { return 37; }

	if ((-1i32 as uint32) != 4294967295u32) { return 38; }
	if ((4294967295u32 as int32) != -1i32) { return 39; }

	if (1i32 << 31) != -2147483648 { return 40; }
	if (-2147483648i32 >> 1) != -1073741824 { return 41; }

	// uint32
	if 0u32 - 1 != 4294967295u32 { return 42; }
	if 4294967295u32 + 1 != 0u32 { return 43; }

	if ~0u32 != 4294967295u32 { return 44; }
	if ~4294967295u32 != 0u32 { return 45; }

	if (1u32 << 31) != 2147483648u32 { return 46; }
	if (4294967295u32 >> 1) != 2147483647u32 { return 47; }

	// int64
	let minI64 = -9223372036854775808i64;
	let maxI64 = 9223372036854775807i64;

	if minI64 - 1 != 9223372036854775807 { return 48; }
	if maxI64 + 1 != -9223372036854775808 { return 49; }

	if ~0i64 != -1 { return 50; }

	if ((-1i64 as uint64) != 18446744073709551615u64) { return 51; }
	if ((18446744073709551615u64 as int64) != -1i64) { return 52; }

	if (1i64 << 63) != -9223372036854775808 { return 53; }
	if (-9223372036854775808i64 >> 1) != -4611686018427387904 { return 54; }

	// uint64
	if 0u64 - 1 != 18446744073709551615u64 { return 55; }
	if 18446744073709551615u64 + 1 != 0u64 { return 56; }

	if ~0u64 != 18446744073709551615u64 { return 57; }
	if ~18446744073709551615u64 != 0u64 { return 58; }

	if (1u64 << 63) != 9223372036854775808u64 { return 59; }
	if (18446744073709551615u64 >> 1) != 9223372036854775807u64 { return 60; }

	// Arithmetic identities
	if 5i32 + 7i32 != 12 { return 61; }
	if 5i32 - 7i32 != -2 { return 62; }
	if -5i32 * 7i32 != -35 { return 63; }
	if -35i32 / 7i32 != -5 { return 64; }
	if -35i32 % 7i32 != 0 { return 65; }

	// Signed division check
	if -7i32 / 2i32 != -3 { return 66; }
	if 7i32 / -2i32 != -3 { return 67; }
	if -7i32 / -2i32 != 3 { return 68; }
	if -7i32 % 2i32 != -1 { return 69; }
	if 7i32 % -2i32 != 1 { return 70; }

	// Comparison operators
	if !(5i32 == 5i32) { return 71; }
	if !(5i32 != 6i32) { return 72; }
	if !(5i32 < 6i32) { return 73; }
	if !(5i32 <= 5i32) { return 74; }
	if !(6i32 > 5i32) { return 75; }
	if !(6i32 >= 6i32) { return 76; }

	// Compound assignments
	var arithX = 10i32;

	arithX += 5;
	if arithX != 15 { return 77; }

	arithX -= 3;
	if arithX != 12 { return 78; }

	arithX *= 2;
	if arithX != 24 { return 79; }

	arithX /= 4;
	if arithX != 6 { return 80; }

	arithX %= 4;
	if arithX != 2 { return 81; }

	// Bit masking
	let maskX = 0xABu8;

	if (maskX & 0x0F) != 0x0B { return 82; }
	if (maskX & 0xF0) != 0xA0 { return 83; }

	// Shift edge cases
	if (1u32 << 0) != 1 { return 84; }
	if (128u8 >> 7) != 1 { return 85; }
	if (-1i8 >> 1) != -1 { return 86; }

	// Cast chains
	let castX = -1i8;

	if ((castX as int16) != -1) { return 87; }
	if ((castX as int32) != -1) { return 88; }
	if ((castX as int64) != -1) { return 89; }

	// Narrowing truncation
	if ((300i32 as int8) != 44) { return 90; }
	if ((0xDEADBEEFu32 as uint8) != 0xEFu8) { return 91; }

	// Constant folding
	const A = 10 + 20;
	if A != 30 { return 92; }

	const B = (5 * 3) - 2;
	if B != 13 { return 93; }

	// Operator precedence
	if 2 + 3 * 4 != 14 { return 94; }
	if (2 + 3) * 4 != 20 { return 95; }
	if 8 >> 1 + 1 != 2 { return 96; }

	// Unary operators
	if -(5i32) != -5 { return 97; }
	if ~0u32 != 0xFFFFFFFFu32 { return 98; }

	// Bitwise OR/XOR
	if (0b1100u8 | 0b1010u8) != 14 { return 99; }
	if (0b1100u8 ^ 0b1010u8) != 6 { return 100; }

	// Compound bitwise assignments
	var flags = 0b1100u8;

	flags &= 0b1010u8;
	if flags != 8 { return 101; }

	flags = 0b1100u8;
	flags |= 0b0011u8;
	if flags != 15 { return 102; }

	flags = 0b1100u8;
	flags ^= 0b1010u8;
	if flags != 6 { return 103; }

	// Compound shifts
	var shift = 1u32;

	shift <<= 5;
	if shift != 32 { return 104; }

	shift >>= 2;
	if shift != 8 { return 105; }

	// Shift examples
	if (20u8 << 2) != 80 { return 106; }
	if (20u8 >> 2) != 5 { return 107; }
	if (-8i8 >> 2) != -2 { return 108; }

	// Shift as multiply/divide
	if (5i32 << 3) != 40 { return 109; }
	if (5i32 >> 2) != 1 { return 110; }

	// Literal forms
	if 0xFF != 255 { return 111; }
	if 0o755 != 493 { return 112; }
	if 0b10101010 != 170 { return 113; }

	// Unsigned widening (zero extension)
	let widen = 255u8;

	if (widen as uint16) != 255u16 { return 114; }
	if (widen as uint32) != 255u32 { return 115; }
	if (widen as uint64) != 255u64 { return 116; }

	// Signed -> unsigned widening
	let neg = -1i8;

	if ((neg as uint32) != 4294967295u32) {
		return 117;
	}

	// Associativity
	if 20 - 10 - 5 != 5 { return 118; }

	// Double complement identity
	if ~~123i32 != 123 { return 119; }

	// XOR identity
	if (0x55u8 ^ 0x55u8) != 0 { return 120; }

	// AND identity
	if (0xABu8 & 0xFFu8) != 0xABu8 { return 121; }

	// OR identity
	if (0xABu8 | 0u8) != 0xABu8 { return 122; }

	return 0;
}
