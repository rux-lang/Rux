// Verifies that hex, binary, and octal integer literals accept a type suffix
// (e.g. 0xFFu), the same way decimal literals already do. Before the fix the
// lexer treated the suffix letter as an invalid digit for the base and errored
// ("invalid digit 'u' for base 16"). Also checks '_' digit separators.
//
// Returns 0 when every value matches; otherwise the 1-based index of the first
// failing check, so a non-zero exit pinpoints the broken case.
// Tests/run_numeric_suffix_test.sh asserts the exit code.

func Main() -> int {
    if 0xFFu != 255 { return 1; }
    if 0b1010u != 10 { return 2; }
    if 0o17i != 15 { return 3; }
    if 0xDE_AD != 57005 { return 4; }
    if 0b1111_1111 != 255 { return 5; }
    if 0xFF != 255 { return 6; }
    return 0;
}
