func Main() -> int {
    // Writing through a read-only pointer '*T' (from a plain '@') is forbidden.
    let a = 10;
    let p = @a;
    *p = 50;

    // A read-only '*T' cannot be laundered into a writable '*mut T' binding.
    let mut r: *mut int = @a;

    // Control: '@mut' on a `let mut` yields a writable '*mut int'.
    let mut b = 20;
    let q = @mut b;
    *q = 60;

    return 0;
}
