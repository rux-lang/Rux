func Main() -> int {
    // Writing through a read-only pointer '*T' (from a plain '@') is forbidden.
    let a = 10;
    let p = @a;
    *p = 50;

    // A read-only '*T' cannot be laundered into a writable '*var T' binding.
    var r: *var int = @a;

    // Control: '@' on a `var` yields a writable '*var int'.
    var b = 20;
    let q = @b;
    *q = 60;

    return 0;
}
