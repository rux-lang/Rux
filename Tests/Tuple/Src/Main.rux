import Std::Assert;

func divide(a: int, b: int) -> (int, bool) {
    if b == 0 {
        return (0, false);
    }
    return (a / b, true);
}

func Main() -> int
{
    let pair: (int, float) = (1, 3.1415);
    Assert(pair.0 == 1, "Expected pair.0 to be 1");
    Assert(pair.1 - 3.1415 < 0.001, "Expected pair.1 to be 3.1415");

    let (x, y) = pair; // Destructuring assignment
    Assert(x == 1, "Expected x to be 1");
    Assert(y - 3.1415 < 0.001, "Expected y to be 3.1415");

    Assert(sizeof((int, float)) == 16, "Expected size of pair to be 16 bytes");

    let (result, ok) = divide(10, 0);
    if ok {
        Assert(false, "Expected division by zero to fail");
    } else {
        Assert(true, "Expected division by zero to fail");
    }
    return 0;
}