// Verifies string and char escape decoding, in particular the \u{...} Unicode
// escape. The lexer accepts \u{...} (and range-checks it), but the HIR string
// and char decoders used to have no case for it, so "\u{41}" decoded to the
// literal text {41} instead of "A". This checks the decoded bytes directly.
//
// Returns 0 when every check passes; otherwise the 1-based index of the first
// failing check, so a non-zero exit code points straight at the broken case.
// Tests/run_unicode_test.sh asserts the exit code.

func Main() -> int {
    // ASCII code point: \u{41} == "A"
    let a = "\u{41}";
    if a.length != 1 { return 1; }
    if a.data[0] != 0x41 { return 2; }

    // 2-byte UTF-8: U+00E9 == 0xC3 0xA9
    let e = "\u{E9}";
    if e.length != 2 { return 3; }
    if e.data[0] != 0xC3 { return 4; }
    if e.data[1] != 0xA9 { return 5; }

    // 3-byte UTF-8: U+4E2D == 0xE4 0xB8 0xAD
    let z = "\u{4E2D}";
    if z.length != 3 { return 6; }
    if z.data[0] != 0xE4 { return 7; }
    if z.data[1] != 0xB8 { return 8; }
    if z.data[2] != 0xAD { return 9; }

    // 4-byte UTF-8 (astral plane): U+1F600 == 0xF0 0x9F 0x98 0x80
    let g = "\u{1F600}";
    if g.length != 4 { return 10; }
    if g.data[0] != 0xF0 { return 11; }
    if g.data[1] != 0x9F { return 12; }
    if g.data[2] != 0x98 { return 13; }
    if g.data[3] != 0x80 { return 14; }

    // A char literal decodes to the code point value itself.
    let c = '\u{1F600}';
    if c != 128512 { return 15; }

    // The existing escapes still decode correctly.
    let r = "\t\n\\";
    if r.length != 3 { return 16; }
    if r.data[0] != 0x09 { return 17; }
    if r.data[1] != 0x0A { return 18; }
    if r.data[2] != 0x5C { return 19; }

    return 0;
}
