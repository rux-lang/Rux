// Regression test for issue #197: a @[Target(...)] annotation on a method
// inside an `extend` block used to fail with "expected 'func' in extend body".
// The extend-body parser now consumes leading attributes before each method,
// so the program below compiles cleanly on every host (the target-gated method
// is simply dropped when the host OS does not match).
struct Animal {}

extend Animal {
    @[Target("Linux")]
    func Talk() {}

    func Legs(self) -> int {
        return 4;
    }
}

func Main() -> int {
    let a = Animal{};
    return a.Legs() - 4;
}
