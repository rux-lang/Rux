// SSE/SSE2 asm functions. On Win64 the first float64 arguments arrive in
// xmm0, xmm1, ...; a float64 result is returned in xmm0.

// Square root of a double: sqrtsd computes it in place in xmm0.
asm func Sqrt(x: float64) -> float64 {
    sqrtsd xmm0, xmm0
    ret
}

// a * b + c, exercising a second and third float argument (xmm1, xmm2).
asm func MulAdd(a: float64, b: float64, c: float64) -> float64 {
    mulsd xmm0, xmm1
    addsd xmm0, xmm2
    ret
}

// Round-trip a double through a GP register with movq, then take min/max.
asm func MinOf(a: float64, b: float64) -> float64 {
    minsd xmm0, xmm1
    ret
}

// Convert an integer argument (rcx) to a double result: cvtsi2sd + movq back.
asm func IntToFloat(n: int64) -> float64 {
    cvtsi2sd xmm0, rcx
    ret
}

// Truncate a double back to an integer (returned in rax).
asm func FloatToInt(x: float64) -> int64 {
    cvttsd2si rax, xmm0
    ret
}
