@[Target("Linux")]
asm func LinuxAdd(a: int64, b: int64) -> int64 {
    mov rax, rdi
    add rax, rsi
    ret
}

@[Target("Linux")]
asm func LinuxGetPid() -> int64 {
    mov rax, 39
    syscall
    ret
}

@[Target("Linux")]
func PlatformAbiCheck() -> int {
    if LinuxAdd(20, 22) != 42 {
        return 1;
    }
    if LinuxGetPid() <= 0 {
        return 2;
    }
    return 0;
}

@[Target("Windows")]
func PlatformAbiCheck() -> int { return 0; }

@[Target("macOS")]
func PlatformAbiCheck() -> int { return 0; }

@[Target("BSD")]
func PlatformAbiCheck() -> int { return 0; }

@[Target("Illumos")]
func PlatformAbiCheck() -> int { return 0; }
