import Rux::Assert;

func Max<T>(a: T, b: T) -> T {
    if (a > b) {
        return a;
    } else {
        return b;
    }
}

func Main() -> int {
    let x = Max<int32>(5, 10);
    Assert(x == 10, "Expected 10");
    let y = Max<float64>(3.14, 2.71);
    Assert(y == 3.14, "Expected 3.14");
    return 0;
}

