func MustNotRun() -> bool {
    var zero = 0;
    let failure = 1 / zero;
    return false;
}

func Main() -> int {
    var condition = true;
    Assert(condition, "Assert works without an import");

    #if #build.debugAssertions {
        DebugAssert(condition, "DebugAssert is active in debug builds");
    } else {
        DebugAssert(MustNotRun(), "DebugAssert does not evaluate arguments in release builds");
    }

    return 0;
}
