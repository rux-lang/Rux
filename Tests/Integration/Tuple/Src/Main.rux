import Std::Assert;

func divide(a: int, b: int) -> (int, bool) {
    if b == 0 {
        return (0, false);
    }
    return (a / b, true);
}

func makePair() -> (int, float) {
    return (1, 3.1415);
}

func makeTriple() -> (int64, int64, int64) {
    return (11, 22, 33);
}

func makeNested() -> ((int16, int64), uint8) {
    return ((-123, 456), 255);
}

func Main() -> int {
    let pair: (int, float) = (1, 3.1415);
    Assert(sizeof((int, float)) == 16, "Expected size of pair to be 16 bytes");
    Assert(pair.0 == 1, "Expected pair.0 to be 1");
    Assert(pair.1 - 3.1415 < 0.001, "Expected pair.1 to be 3.1415");

    let (x, y) = pair;
    Assert(x == 1, "Expected x to be 1");
    Assert(y - 3.1415 < 0.001, "Expected y to be 3.1415");

    let returned = makePair();
    Assert(returned.0 == 1, "Expected returned.0 to be 1");
    Assert(returned.1 - 3.1415 < 0.001, "Expected returned.1 to be 3.1415");

    let triple = makeTriple();
    Assert(sizeof((int64, int64, int64)) == 24, "Expected size of triple to be 24 bytes");
    Assert(triple.0 == 11i64, "Expected triple.0 to be 11");
    Assert(triple.1 == 22i64, "Expected triple.1 to be 22");
    Assert(triple.2 == 33i64, "Expected triple.2 to be 33");

    let nested = makeNested();
    let inner = nested.0;
    Assert(inner.0 == -123, "Expected nested.0.0 to be -123");
    Assert(inner.1 == 456i64, "Expected nested.0.1 to be 456");
    Assert(nested.1 == 255, "Expected nested.1 to be 255");

    let (quotient, ok) = divide(10, 2);
    Assert(ok, "Expected division by non-zero to succeed");
    Assert(quotient == 5, "Expected 10 / 2 to be 5");

    let (failedQuotient, failedOk) = divide(10, 0);
    Assert(!failedOk, "Expected division by zero to fail");
    Assert(failedQuotient == 0, "Expected failed division quotient to be 0");

    return 0;
}
