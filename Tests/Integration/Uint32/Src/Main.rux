import Rux::Assert;

func Main() -> int {
    let a: uint32 = 100000;
    let b: uint32 = 300;

    Assert(a + b == 100300, "uint32 addition");
    Assert(a - b == 99700, "uint32 subtraction");
    Assert(a * b == 30000000, "uint32 multiplication");
    Assert(a / b == 333, "uint32 division truncates");
    Assert(a % b == 100, "uint32 modulo");

    let min: uint32 = 0;
    let max: uint32 = 0xFFFFFFFF;
    Assert(min == 0, "uint32 min is 0");
    Assert(max == 0xFFFFFFFF, "uint32 max is 0xFFFFFFFF");

    let wrap_add: uint32 = (max + 1) as uint32;
    Assert(wrap_add == 0, "uint32 addition wraps at 2^32");

    let wrap_sub: uint32 = (0 - 1) as uint32;
    Assert(wrap_sub == 0xFFFFFFFF, "uint32 subtraction wraps below 0");

    Assert(1000 as uint32 == 1000 as uint32, "uint32 equality");
    Assert(1000 as uint32 != 1001 as uint32, "uint32 inequality");
    Assert(999 as uint32 < 1000 as uint32, "uint32 less-than");
    Assert(1000 as uint32 <= 1000 as uint32, "uint32 less-than-or-equal");
    Assert(1000 as uint32 > 999 as uint32, "uint32 greater-than");
    Assert(1000 as uint32 >= 1000 as uint32, "uint32 greater-than-or-equal");

    Assert((0x00FF00FF as uint32 & 0x0F0F0F0F as uint32) == 0x000F000F, "uint32 bitwise AND");
    Assert((0x00FF00FF as uint32 | 0x0F0F0F0F as uint32) == 0x0FFF0FFF, "uint32 bitwise OR");
    Assert((0x00FF00FF as uint32 ^ 0x0F0F0F0F as uint32) == 0x0FF00FF0, "uint32 bitwise XOR");
    Assert((~0x000000FF as uint32) == 0xFFFFFF00, "uint32 bitwise NOT");

    Assert((1 as uint32 << 16) == 65536, "uint32 left shift");
    Assert((0x80000000 as uint32 >> 24) == 0x80, "uint32 right shift is logical");
    Assert((1 as uint32 << 31) == 0x80000000, "uint32 left shift to MSB");

    let u: uint32 = 4000000000;
    let w64: uint64 = u as uint64;
    Assert(w64 == 4000000000, "uint32 zero-extends to uint64");

    let high: uint32 = 0xFFFFFF80;
    let as_i32: int32 = high as int32;
    Assert(as_i32 == -128, "uint32 0xFFFFFF80 reinterprets as int32 -128");

    let wide: uint64 = 0x00000001FFFFFFFF;
    let narrow: uint32 = wide as uint32;
    Assert(narrow == 0xFFFFFFFF, "uint64 to uint32 truncates to low dword");

    var x: uint32 = 5;
    x = x + 1;
    Assert(x == 6, "uint32 var mutation via addition");
    x += 10;
    Assert(x == 16, "uint32 compound += operator");
    x -= 6;
    Assert(x == 10, "uint32 compound -= operator");
    x *= 2;
    Assert(x == 20, "uint32 compound *= operator");
    x /= 4;
    Assert(x == 5, "uint32 compound /= operator");
    x %= 3;
    Assert(x == 2, "uint32 compound %= operator");

    let small: uint32 = 42;
    let big: uint = small;
    Assert(big == 42, "uint32 widens implicitly to uint");

    let lit1 = 100000u32;
    let lit2 = 4294967295u32;
    Assert(lit1 == 100000, "uint32 literal with u32 suffix");
    Assert(lit2 == 0xFFFFFFFF, "uint32 literal with u32 suffix");

    let hex: uint32 = 0xFFFFFFFF;
    let bin: uint32 = 0b11111111111111111111111111111111;
    Assert(hex == 0xFFFFFFFF, "uint32 hex literal 0xFFFFFFFF");
    Assert(bin == 0xFFFFFFFF, "uint32 binary literal parity value");
    Assert(hex == bin, "uint32 hex and binary literal parity");

    let flag: uint32 = 0;
    Assert(flag == 0, "uint32 zero is falsy-equivalent when compared");
    Assert(!(flag != 0), "uint32 zero not-nonzero");

    let nz = 1u32;
    Assert(nz != 0, "uint32 nonzero value");
    return 0;
}
