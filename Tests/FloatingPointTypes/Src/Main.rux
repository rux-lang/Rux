func Main() -> int {
	// Basic literals
	let f32 = 3.5f32;
	let f64 = 3.5f64;

	if f32 != 3.5f32 { return 1; }
	if f64 != 3.5f64 { return 2; }

	// Default float type
	let d = 1.5;
	if d != 1.5 { return 3; }

	// Arithmetic
	if 1.5 + 2.5 != 4.0 { return 4; }
	if 5.5 - 2.0 != 3.5 { return 5; }
	if 3.0 * 4.0 != 12.0 { return 6; }
	if 10.0 / 4.0 != 2.5 { return 7; }

	// Floating remainder
	if 5.5 % 2.0 != 1.5 { return 8; }

	// Unary operators
	if -5.0 != -5.0 { return 9; }

	// Compound assignments
	var x = 10.0;

	x += 5.0;
	if x != 15.0 { return 10; }

	x -= 3.0;
	if x != 12.0 { return 11; }

	x *= 2.0;
	if x != 24.0 { return 12; }

	x /= 4.0;
	if x != 6.0 { return 13; }

	// Comparisons
	if !(1.0 == 1.0) { return 14; }
	if !(1.0 != 2.0) { return 15; }
	if !(1.0 < 2.0) { return 16; }
	if !(1.0 <= 1.0) { return 17; }
	if !(2.0 > 1.0) { return 18; }
	if !(2.0 >= 2.0) { return 19; }

	// Scientific notation
	if 1.0e3 != 1000.0 { return 20; }
	if 1.5e2 != 150.0 { return 21; }
	if 1.0e-2 != 0.01 { return 22; }

	// Integer -> float
	let i32 = 42i32;
	let f = i32 as float64;

	if f != 42.0 { return 23; }

	// Float -> integer truncation
	if (42.9 as int32) != 42 { return 24; }
	if (-42.9 as int32) != -42 { return 25; }

	// Widening
	let small = 1.25f32;
	let wide: float64 = small;

	if wide != 1.25 { return 26; }

	// Narrowing
	let big = 1.25f64;
	let narrow = big as float32;

	if narrow != 1.25f32 { return 27; }

	// Constant folding
	const A = 1.5 + 2.5;
	if A != 4.0 { return 28; }

	const B = (10.0 / 2.0) * 3.0;
	if B != 15.0 { return 29; }

	// Operator precedence
	if 2.0 + 3.0 * 4.0 != 14.0 { return 30; }
	if (2.0 + 3.0) * 4.0 != 20.0 { return 31; }

	// Negative zero
	let negZero = -0.0;

	if negZero != 0.0 { return 32; }

	// Infinity
	let posInf = 1.0 / 0.0;

	if !(posInf > 1.0e300) { return 33; }

	let negInf = -1.0 / 0.0;

	if !(negInf < -1.0e300) { return 34; }

	// NaN
	let nan = 0.0 / 0.0;

	if nan == nan { return 35; }
	if !(nan != nan) { return 36; }

	// Infinity propagation
	if ((1.0 / 0.0) + 1.0) != (1.0 / 0.0) {
		return 37;
	}

	// Large float64 exact integer
	let exact = 9007199254740992.0;

	if exact != 9007199254740992.0 {
		return 38;
	}

	return 0;
}
