func IsNan(value: float64) -> bool {
    return value != value;
}

func IsInfinite(value: float64) -> bool {
    return value - value != 0.0;
}

func Main() -> int {
	// Basic literals
	let f32 = 3.5f32;
	let f64 = 3.5f64;

	if f32 != 3.5f32 { return 1; }
	if f64 != 3.5f64 { return 2; }

	// Default float type
	let d = 1.5;
	if d != 1.5 { return 3; }

	// Arithmetic
	if 1.5 + 2.5 != 4.0 { return 4; }
	if 5.5 - 2.0 != 3.5 { return 5; }
	if 3.0 * 4.0 != 12.0 { return 6; }
	if 10.0 / 4.0 != 2.5 { return 7; }
	// if 9.0 ** 0.5 != 3.0 { return 8; }

	// Floating remainder
	if (7.0 % -3.0 != 1.0) || (-7.0 % 3.0 != -1.0) { return 9; }

	// Unary operators
	if -5.0 != -5.0 { return 10; }

	// Compound assignments
	var x = 10.0;

	x += 5.0;
	if x != 15.0 { return 11; }

	x -= 3.0;
	if x != 12.0 { return 12; }

	x *= 2.0;
	if x != 24.0 { return 13; }

	x /= 4.0;
	if x != 6.0 { return 14; }

	// Comparisons
	if !(1.0 == 1.0) { return 15; }
	if !(1.0 != 2.0) { return 16; }
	if !(1.0 < 2.0) { return 17; }
	if !(1.0 <= 1.0) { return 18; }
	if !(2.0 > 1.0) { return 19; }
	if !(2.0 >= 2.0) { return 20; }

	// Scientific notation
	if 1.0e3 != 1000.0 { return 21; }
	if 1.5e2 != 150.0 { return 22; }
	if 1.0e-2 != 0.01 { return 23; }

	// Integer -> float
	let i32 = 42i32;
	let f = i32 as float64;

	if f != 42.0 { return 24; }

	// Float -> integer truncation
	if (42.9 as int32) != 42 { return 25; }
	if (-42.9 as int32) != -42 { return 26; }

	// Widening
	let small = 1.25f32;
	let wide: float64 = small;

	if wide != 1.25 { return 27; }

	// Narrowing
	let big = 1.25f64;
	let narrow = big as float32;

	if narrow != 1.25f32 { return 28; }

	// Constant folding
	const A = 1.5 + 2.5;
	if A != 4.0 { return 29; }

	const B = (10.0 / 2.0) * 3.0;
	if B != 15.0 { return 30; }

	// Operator precedence
	if 2.0 + 3.0 * 4.0 != 14.0 { return 31; }
	if (2.0 + 3.0) * 4.0 != 20.0 { return 32; }

	// Negative zero
	let negZero = -0.0;

	if negZero != 0.0 { return 33; }

	// Infinity
	let posInf = 1.0 / 0.0;
	let negInf = -1.0 / 0.0;

	if !IsInfinite(posInf) { return 34; }
    if !IsInfinite(negInf) { return 35; }

	// NaN
	let nan = 0.0 / 0.0;

	if !IsNan(nan) { return 36; }
    if IsNan(1.0) { return 37; }

	// Infinity propagation
	if !IsInfinite((1.0 / 0.0) + 1.0) {
        return 38;
    }

	// Large float64 exact integer
	let exact = 9007199254740992.0;

	if exact != 9007199254740992.0 {
		return 39;
	}

	return 0;
}
