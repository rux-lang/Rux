import Rux::Assert;
import Math::Floor;

func Main() -> int {
    let mut zero = 0.0;
    let mut one = 1.0;
    let inf = one / zero;

    Assert(Floor(0.0) == 0.0, "Floor(0.0)");
    let negZero = Floor(-0.0);
    Assert(negZero == 0.0, "Floor(-0.0)");
    Assert(one / negZero < 0.0, "Floor(-0.0) keeps sign");

    Assert(Floor(1.2) == 1.0, "Floor(1.2)");
    Assert(Floor(1.0) == 1.0, "Floor(1.0)");
    Assert(Floor(-1.2) == -2.0, "Floor(-1.2)");
    Assert(Floor(-1.0) == -1.0, "Floor(-1.0)");
    Assert(Floor(0.5) == 0.0, "Floor(0.5)");
    Assert(Floor(-0.5) == -1.0, "Floor(-0.5)");
    Assert(Floor(4503599627370496.5) == 4503599627370496.0, "Floor(2^52)");

    Assert(Floor(inf) == inf, "Floor(+Inf)");
    Assert(Floor(-inf) == -inf, "Floor(-Inf)");
    let nan = zero / zero;
    let nanFloor = Floor(nan);
    Assert(nanFloor != nanFloor, "Floor(NaN)");

    Assert(Floor(1.2f32) == 1.0f32, "Floor(1.2f32)");
    Assert(Floor(-1.2f32) == -2.0f32, "Floor(-1.2f32)");
    return 0;
}
