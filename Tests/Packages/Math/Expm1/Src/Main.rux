import Rux::Assert;
import Math::Expm1;

asm func BitsOf(x: float64) -> int64 {
    movq rax, xmm0
    ret
}

func Close(actual: float64, expected: float64) -> bool {
    if actual != actual {
        return false;
    }
    if actual < 0.0 {
        if expected >= 0.0 {
            return false;
        }
    }
    if actual >= 0.0 {
        if expected < 0.0 {
            return false;
        }
    }
    let mut gap = BitsOf(actual) - BitsOf(expected);
    if gap < 0i64 {
        gap = -gap;
    }
    return gap <= 2i64;
}

func Main() -> int {
    let mut zero = 0.0;
    let mut one = 1.0;
    let inf = one / zero;

    Assert(Expm1(0.0) == 0.0, "Expm1(0.0)");
    Assert(BitsOf(Expm1(-0.0)) == BitsOf(-0.0), "Expm1(-0.0)");
    Assert(Close(Expm1(1.0), 1.7182818284590453), "Expm1(1.0)");
    Assert(Close(Expm1(-1.0), -0.6321205588285577), "Expm1(-1.0)");
    Assert(Close(Expm1(0.5), 0.6487212707001282), "Expm1(0.5)");
    Assert(Close(Expm1(-0.5), -0.3934693402873666), "Expm1(-0.5)");
    Assert(Close(Expm1(10.0), 22025.465794806718), "Expm1(10.0)");

    Assert(Expm1(1.0e-16) == 1.0e-16, "Expm1(small positive)");
    Assert(Expm1(-1.0e-16) == -1.0e-16, "Expm1(small negative)");
    Assert(Expm1(710.0) == inf, "Expm1 overflow");
    Assert(Expm1(-100.0) == -1.0, "Expm1 large negative");
    Assert(Expm1(inf) == inf, "Expm1(+Inf)");
    Assert(Expm1(-inf) == -1.0, "Expm1(-Inf)");

    let nanExpm1 = Expm1(zero / zero);
    Assert(nanExpm1 != nanExpm1, "Expm1(NaN)");

    return 0;
}
