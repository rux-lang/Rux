import Rux::Assert;
import Math::Mod;

asm func BitsOf(x: float64) -> int64 {
    movq rax, xmm0
    ret
}

func Close(actual: float64, expected: float64) -> bool {
    if actual != actual {
        return false;
    }
    if actual < 0.0 {
        if expected >= 0.0 {
            return false;
        }
    }
    if actual >= 0.0 {
        if expected < 0.0 {
            return false;
        }
    }
    let mut gap = BitsOf(actual) - BitsOf(expected);
    if gap < 0i64 {
        gap = -gap;
    }
    return gap <= 1i64;
}

func Main() -> int {
    let mut zero = 0.0;
    let mut one = 1.0;
    let inf = one / zero;

    Assert(Mod(5.0, 2.0) == 1.0, "Mod(5, 2)");
    Assert(Mod(4.0, 2.0) == 0.0, "Mod exact division");
    let negExact = Mod(-4.0, 2.0);
    Assert(negExact == 0.0, "Mod negative exact division");
    Assert(one / negExact < 0.0, "Mod exact division keeps x sign");
    Assert(Close(Mod(5.3, 2.0), 1.2999999999999998), "Mod(5.3, 2)");
    Assert(Close(Mod(-5.3, 2.0), -1.2999999999999998), "Mod(-5.3, 2)");
    Assert(Close(Mod(5.3, -2.0), 1.2999999999999998), "Mod(5.3, -2)");
    Assert(Mod(1.0, 2.0) == 1.0, "Mod smaller dividend");
    let negSmall = Mod(-1.0, 2.0);
    Assert(negSmall == -1.0, "Mod negative smaller dividend");

    let zeroDiv = Mod(1.0, 0.0);
    Assert(zeroDiv != zeroDiv, "Mod divisor zero");
    let infDividend = Mod(inf, 2.0);
    Assert(infDividend != infDividend, "Mod infinite dividend");
    let nanMod = Mod(zero / zero, 2.0);
    Assert(nanMod != nanMod, "Mod NaN dividend");

    Assert(Mod(5.5f32, 2.0f32) == 1.5f32, "Mod f32");
    return 0;
}
