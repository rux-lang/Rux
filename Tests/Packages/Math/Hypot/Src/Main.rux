import Rux::Assert;
import Math::Hypot;

asm func BitsOf(x: float64) -> int64 {
    movq rax, xmm0
    ret
}

func Close(actual: float64, expected: float64) -> bool {
    if actual != actual {
        return false;
    }
    if actual < 0.0 {
        return false;
    }
    let mut gap = BitsOf(actual) - BitsOf(expected);
    if gap < 0i64 {
        gap = -gap;
    }
    return gap <= 2i64;
}

func Main() -> int {
    let mut zero = 0.0;
    let mut one = 1.0;
    let inf = one / zero;

    Assert(Hypot(0.0, 0.0) == 0.0, "Hypot(0, 0)");
    Assert(Hypot(-0.0, 0.0) == 0.0, "Hypot(-0, 0)");
    Assert(Hypot(3.0, 4.0) == 5.0, "Hypot(3, 4)");
    Assert(Hypot(-3.0, 4.0) == 5.0, "Hypot(-3, 4)");
    Assert(Hypot(5.0, 12.0) == 13.0, "Hypot(5, 12)");
    Assert(Close(Hypot(1e300, 1e300), 1.4142135623730952e300), "Hypot huge");
    Assert(Close(Hypot(1e-300, 1e-300), 1.414213562373095e-300), "Hypot tiny");
    Assert(Hypot(inf, 1.0) == inf, "Hypot(+Inf, finite)");
    Assert(Hypot(1.0, -inf) == inf, "Hypot(finite, -Inf)");
    Assert(Hypot(inf, zero / zero) == inf, "Hypot(+Inf, NaN)");

    let nanHypot = Hypot(zero / zero, 1.0);
    Assert(nanHypot != nanHypot, "Hypot(NaN, finite)");

    Assert(Hypot(3.0f32, 4.0f32) == 5.0f32, "Hypot(3f32, 4f32)");
    return 0;
}
