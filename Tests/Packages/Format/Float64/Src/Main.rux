import Format::{ ToString, IsNan, IsInfinite, IsFinite, ParseError, ParseFloat64, TryParseFloat64 };
import Rux::Result;
import Text::String;

// Std is deliberately absent from the dependencies: it exports conversions of
// the same name, and the compiler pools the overloads of two same-named symbols,
// so Std's would win over this package's and the code under test would never
// run. That rules out Std::Assert, so a failed check reports itself through the
// exit code instead: each one below is numbered, and `rux test` prints the
// number of the first that fails.
func Check(value: float64, expected: Slice<char8>, code: int) -> int {
    let mut actual = ToString(value);
    let mut wanted = String::From(expected);
    let ok = actual == wanted;
    actual.Free();
    wanted.Free();

    if ok {
        return 0;
    }
    return code;
}

func CheckParse(str: Slice<char8>, expected: float64, code: int) -> int {
    let result = ParseFloat64(str);
    return match result {
        Result::Success(value) => value == expected ? 0 : code,
        Result::Error(_) => code
    };
}

func CheckParseError(str: Slice<char8>, expected: ParseError, code: int) -> int {
    let result = ParseFloat64(str);
    return match result {
        Result::Success(_) => code,
        Result::Error(error) => error == expected ? 0 : code
    };
}

func CheckParsedValues() -> int {
    let mut code = CheckParse("0", 0.0, 100);
    if code != 0 { return code; }
    code = CheckParse("-2.5", -2.5, 101);
    if code != 0 { return code; }
    code = CheckParse(".125", 0.125, 102);
    if code != 0 { return code; }
    code = CheckParse("1.25e3", 1250.0, 103);
    if code != 0 { return code; }
    return CheckParse("5e-2", 0.05, 104);
}

func CheckParseErrors() -> int {
    let mut code = CheckParseError("", ParseError::Empty, 110);
    if code != 0 { return code; }
    code = CheckParseError("12x", ParseError::InvalidCharacter(2u), 111);
    if code != 0 { return code; }
    return CheckParseError("1e400", ParseError::Overflow, 112);
}

func CheckParseOverloads() -> int {
    let mut text = String::From("3.5");
    let parsed = ParseFloat64(text);
    text.Free();
    let code = match parsed {
        Result::Success(value) => value == 3.5 ? 0 : 120,
        Result::Error(_) => 120
    };
    if code != 0 { return code; }

    let mut value = 9.0;
    if !TryParseFloat64("6.25", @mut value) { return 121; }
    if value != 6.25 { return 122; }
    if TryParseFloat64("invalid", @mut value) { return 123; }
    if value != 6.25 { return 124; }
    if TryParseFloat64("1.0", null) { return 125; }

    text = String::From("-4.5");
    let ok = TryParseFloat64(text, @mut value);
    text.Free();
    if !ok { return 126; }
    if value != -4.5 { return 127; }

    text = String::From("bad");
    let failed = TryParseFloat64(text, @mut value);
    text.Free();
    if failed { return 128; }
    if value != -4.5 { return 129; }
    return 0;
}

func CheckParsing() -> int {
    let code = CheckParsedValues();
    if code != 0 { return code; }
    let errorCode = CheckParseErrors();
    if errorCode != 0 { return errorCode; }
    return CheckParseOverloads();
}

func Main() -> int {
    // Zero always shows a fractional part, so the text reads as a float. The
    // negative zero keeps its sign, which arithmetic alone cannot see.
    let mut code = Check(0.0, "0.0", 10);
    if code != 0 { return code; }
    code = Check(-0.0, "-0.0", 11);
    if code != 0 { return code; }

    // Whole numbers, with the zero fraction spelled out.
    code = Check(1.0, "1.0", 20);
    if code != 0 { return code; }
    code = Check(-1.0, "-1.0", 21);
    if code != 0 { return code; }
    code = Check(42.0, "42.0", 22);
    if code != 0 { return code; }
    code = Check(12000.0, "12000.0", 23);
    if code != 0 { return code; }

    // The digits stop at fifteen, which is what keeps the noise of the binary
    // representation out of the text: 0.1 is really 0.1000000000000000055.
    code = Check(0.1, "0.1", 30);
    if code != 0 { return code; }
    code = Check(0.5, "0.5", 31);
    if code != 0 { return code; }
    code = Check(-2.25, "-2.25", 32);
    if code != 0 { return code; }
    code = Check(3.14159265358979, "3.14159265358979", 33);
    if code != 0 { return code; }
    code = Check(1.0 / 3.0, "0.333333333333333", 34);
    if code != 0 { return code; }

    // Fixed notation holds down to an exponent of -4.
    code = Check(0.001, "0.001", 40);
    if code != 0 { return code; }
    code = Check(0.0001, "0.0001", 41);
    if code != 0 { return code; }

    // Below that, and at fifteen digits of magnitude and up, the exponent form
    // takes over rather than spending the width on zeros.
    code = Check(0.00001, "1.0e-05", 50);
    if code != 0 { return code; }
    code = Check(2.5e-7, "2.5e-07", 51);
    if code != 0 { return code; }
    code = Check(1.0e15, "1.0e+15", 52);
    if code != 0 { return code; }
    code = Check(-1.5e20, "-1.5e+20", 53);
    if code != 0 { return code; }
    code = Check(1.0e300, "1.0e+300", 54);
    if code != 0 { return code; }

    // The ends of the range: the largest finite value, and the smallest
    // subnormal, which a single 10^exp scaling would have flushed to zero.
    code = Check(1.7976931348623157e308, "1.79769313486232e+308", 60);
    if code != 0 { return code; }
    code = Check(5.0e-324, "4.94065645841247e-324", 61);
    if code != 0 { return code; }

    // Values that are not numbers at all.
    let nan = 0.0 / 0.0;
    let inf = 1.0 / 0.0;
    code = Check(nan, "NaN", 70);
    if code != 0 { return code; }
    code = Check(inf, "Inf", 71);
    if code != 0 { return code; }
    code = Check(-inf, "-Inf", 72);
    if code != 0 { return code; }

    // The classification the conversion leans on. A NaN is not infinite and not
    // finite; an infinity is not a NaN.
    if !IsNan(nan) { return 80; }
    if IsNan(1.0) { return 81; }
    if !IsInfinite(inf) { return 82; }
    if !IsInfinite(-inf) { return 83; }
    if IsInfinite(nan) { return 84; }
    if IsFinite(nan) { return 85; }
    if IsFinite(inf) { return 86; }
    if !IsFinite(0.0) { return 87; }
    if !IsFinite(1.7976931348623157e308) { return 88; }

    // Decimal parsing returns a typed Result, including the position of an
    // invalid character and a distinct overflow error.
    code = CheckParsing();
    if code != 0 { return code; }

    // The method the Stringable extension provides, which is the same
    // conversion reached through the interface.
    let mut text = 2.5.ToString();
    let mut wanted = String::From("2.5");
    let ok = text == wanted;
    text.Free();
    wanted.Free();
    if !ok { return 90; }

    return 0;
}
