import Format::ToString;
import Text::String;

// Std stays out of the dependencies, and a failed check reports itself through
// the exit code. See the Int8 test for why.
func Check(actual: String, expected: Slice<char8>, code: int) -> int {
    var text = actual;
    var wanted = String::From(expected);
    let ok = text == wanted;
    text.Free();
    wanted.Free();

    if ok {
        return 0;
    }
    return code;
}

func Main() -> int {
    let zero: uint32 = 0;
    var code = Check(ToString(zero), "0", 10);
    if code != 0 { return code; }

    let value: uint32 = 1000000;
    code = Check(ToString(value), "1000000", 11);
    if code != 0 { return code; }

    // The largest uint32, which is a value an int32 could not have held: an
    // unsigned type spends on magnitude what a signed one spends on the sign.
    let max: uint32 = 4294967295;
    code = Check(ToString(max), "4294967295", 20);
    if code != 0 { return code; }

    // The method the Stringable extension provides.
    code = Check(max.ToString(), "4294967295", 30);
    if code != 0 { return code; }

    return 0;
}
