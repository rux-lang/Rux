import Format::ToString;
import Text::String;

// Std stays out of the dependencies, and a failed check reports itself through
// the exit code. See the Int8 test for why.
func Check(actual: String, expected: char8[], code: int) -> int {
    var text = actual;
    var wanted = String::From(expected);
    let ok = text == wanted;
    text.Free();
    wanted.Free();

    if ok {
        return 0;
    }
    return code;
}

func Main() -> int {
    // A bool prints as one of the two words it can name, never as 0 or 1.
    let yes: bool8 = true;
    let no: bool8 = false;
    var code = Check(ToString(yes), "true", 10);
    if code != 0 { return code; }
    code = Check(ToString(no), "false", 11);
    if code != 0 { return code; }

    // A bool that came out of a comparison rather than out of a literal, which
    // is where most of them come from.
    let compared = 2 > 1;
    code = Check(ToString(compared), "true", 20);
    if code != 0 { return code; }

    // The method the Stringable extension provides, which is the same conversion
    // reached through the interface.
    code = Check(yes.ToString(), "true", 30);
    if code != 0 { return code; }

    return 0;
}
