import Format::ToString;
import Text::String;

// Std stays out of the dependencies, and a failed check reports itself through
// the exit code. See the Int8 test for why.
func Check(actual: String, expected: Slice<char8>, code: int) -> int {
    var text = actual;
    var wanted = String::From(expected);
    let ok = text == wanted;
    text.Free();
    wanted.Free();

    if ok {
        return 0;
    }
    return code;
}

func Main() -> int {
    let zero: uint64 = 0;
    var code = Check(ToString(zero), "0", 10);
    if code != 0 { return code; }

    let value: uint64 = 9876543210;
    code = Check(ToString(value), "9876543210", 11);
    if code != 0 { return code; }

    // uint64 is the type every unsigned conversion widens to, so its largest
    // value is the one the digit buffer is sized for: twenty digits, and the
    // only value that fills it.
    let max: uint64 = 18446744073709551615;
    code = Check(ToString(max), "18446744073709551615", 20);
    if code != 0 { return code; }

    // The method the Stringable extension provides.
    code = Check(max.ToString(), "18446744073709551615", 30);
    if code != 0 { return code; }

    return 0;
}
