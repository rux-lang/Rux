import Rux::{
    Assert, #target, OperatingSystem, Architecture, Endianness, DataModel,
    ObjectFormat
};
// TargetFeature is imported by the commented-out HasFeature check at the end.

func Main() -> int {
    // The #target is fully identified: OS, architecture, data model and object
    // format are all resolved rather than left Unknown.
    Assert(#target.os != OperatingSystem::Unknown, "os");
    Assert(#target.arch != Architecture::Unknown, "arch");
    Assert(#target.dataModel != DataModel::Unknown, "dataModel");
    Assert(#target.objectFormat != ObjectFormat::Unknown, "objectFormat");
    Assert(#target.triple.length > 0, "triple");

    // Endianness is one of the two the enum defines.
    Assert(#target.endian == Endianness::Little || #target.endian == Endianness::Big, "endian");

    // The pointer width is 32 or 64, and it agrees with the architecture: the
    // 64-bit instruction sets carry 64-bit pointers, the 32-bit sets 32-bit ones.
    Assert(#target.pointerBits == 32 || #target.pointerBits == 64, "pointerBits");

    let is64 = #target.arch == Architecture::AArch64
        || #target.arch == Architecture::RISCV64
        || #target.arch == Architecture::X86_64;
    let is32 = #target.arch == Architecture::ARM32
        || #target.arch == Architecture::RISCV32
        || #target.arch == Architecture::X86Bit32;
    if is64 {
        Assert(#target.pointerBits == 64, "64-bit arch has 64-bit pointers");
    }
    if is32 {
        Assert(#target.pointerBits == 32, "32-bit arch has 32-bit pointers");
    }

    // TODO: the Target.HasFeature intrinsic is not yet implemented in the
    // compiler -- calling it crashes at load with STATUS_ENTRYPOINT_NOT_FOUND
    // (0xC0000139). Re-enable this (and the TargetFeature import) once it links.
    // The field-and-architecture invariants above already work.
    //
    // // The feature query is callable and a pure function of its argument.
    // Assert(#target.HasFeature(TargetFeature::SSE2) == #target.HasFeature(TargetFeature::SSE2),
    //     "HasFeature deterministic");
    return 0;
}
