import Rux::Assert;

enum Direction {
    North = 10,
    South = 20,
    East = 30,
    West = 40
}

enum Color: uint8 {
    Red = 0,
    Green = 10,
    Blue = 20
}

enum Option {
    Some(int32),
    None
}

enum Shape {
    Circle { radius: float64; },
    Rect { width: float64; height: float64; },
    Point
}

func IdentityDirection(direction: Direction) -> Direction {
    return direction;
}

func Main() -> int {
    Assert(IdentityDirection(Direction::North) == Direction::North,
           "Expected enum argument and return types to match");
    let shape = Shape::Rect { width: 10.0, height: 20.0 };
    let val = match shape {
        .Circle { radius } => radius,
        .Rect { width, height } => (width * height),
        .Point => 0.0
    };
    Assert(val == 200.0, "Expected 200.0");
    let option = Option::Some(7);
    let optionValue = match option {
        .Some(value) => value,
        .None => 0
    };
    Assert(optionValue == 7, "Expected contextual payload binding");
    let fallback = match 7 {
        0 => 1,
        else => 2
    };
    Assert(fallback == 2, "Expected the else match arm");
    return 0;
}
