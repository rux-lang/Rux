import Rux::Assert;

const HI: uint32 = 5;
const LO: uint32 = 1;
const ZERO: int = 0;

func Main() -> int {
    for i in 0..=10 {
        Assert(i < 11, "loop index out of bounds");
    }

    // Regression test for https://github.com/rux-lang/Rux/issues/161:
    // a range bound whose type is narrower than the range element type
    // (here a uint32 const in a Range<int>) must be widened when stored
    // into the range. Otherwise the bound's high bits are left
    // uninitialized and the loop runs zero times or never terminates.
    let mut exclusive: int = 0;
    for i in ZERO..HI {
        exclusive += 1;
    }
    Assert(exclusive == 5, "const exclusive upper bound should iterate 5 times");

    let mut inclusive: int = 0;
    for i in ZERO..=HI {
        inclusive += 1;
    }
    Assert(inclusive == 6, "const inclusive upper bound should iterate 6 times");

    let mut both: int = 0;
    for i in LO..HI {
        both += 1;
    }
    Assert(both == 4, "const lower and upper bounds should iterate 4 times");

    // An unsuffixed integer literal adopts the other integer bound's type.
    // Length-like APIs return uint, so `0..length` must also produce uint
    // indices rather than rejecting them at typed call sites.
    let length: uint = 3;
    let mut lastIndex: uint = 0;
    for i in 0..length {
        lastIndex = i;
    }
    Assert(lastIndex == 2, "zero-based range should use its uint upper-bound type");

    // Regression test for https://github.com/rux-lang/Rux/issues/163:
    // when a loop's range bound reuses an in-scope variable name, that bound
    // must be evaluated in the enclosing scope (reading the variable's
    // pre-loop value) before the loop takes over the variable. `for k in k..7`
    // with an outer k=3 iterates over 3..7 (4 times). Because the loop reuses
    // the existing mutable `k` as its induction variable, `k` holds its final
    // value (7) after the loop.
    let mut k: int = 3;
    let mut count: int = 0;
    for k in k..7 {
        count += 1;
    }
    Assert(count == 4, "self-referential range bound should iterate 4 times");
    Assert(k == 7, "reused loop variable should retain its final value");

    // Same reuse semantics for slice iteration: the loop drives the existing
    // `elem`, which retains the last element after the loop.
    let mut nums: Slice<int> = [10, 20, 30];
    let mut elem: int = 99;
    let mut sum: int = 0;
    for elem in nums {
        sum += elem;
    }
    Assert(sum == 60, "slice loop should sum all elements");
    Assert(elem == 30, "reused slice loop variable should retain its final value");

    // A RangeFrom has an initial value and is independently iterable. It is
    // unbounded, so this loop terminates explicitly.
    let from: RangeFrom<int> = 5..;
    let mut fromSum: int = 0;
    for i in from {
        fromSum += i;
        if i == 7 {
            break;
        }
    }
    Assert(fromSum == 18, "RangeFrom should iterate upward from its start");

    return 0;
}
