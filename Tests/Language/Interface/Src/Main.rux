import Rux::Assert;

interface Figure {
    func Area() -> int;
}

struct Square {
    size: int;
}

extend Square : Figure {
    func Area(self) -> int {
        return self.size * self.size;
    }
}

func Main() -> int {
    let mut square = Square { size: 5 };
    let mut area = square.Area();
    Assert(area == 25, "Expected area of the square to be 25");

    let mut fig : Figure = square;
    Assert(fig.Area() == 25, "Expected area of the figure to be 25");
    return 0;
}
