import Rux::{ Architecture, OperatingSystem, #target };

// The Linux ABI check only exists on Linux: its inline assembly uses the System
// V argument registers and the Linux getpid syscall, neither of which means
// anything elsewhere. On every other system the check trivially passes.
when #target.os == OperatingSystem::Linux &&
     #target.arch == Architecture::X86_64 {
    asm func LinuxAdd(a: int64, b: int64) -> int64 {
        mov rax, rdi
        add rax, rsi
        ret
    }

    asm func LinuxGetPid() -> int64 {
        mov rax, 39
        syscall
        ret
    }

    func PlatformAbiCheck() -> int {
        if LinuxAdd(20, 22) != 42 {
            return 1;
        }
        if LinuxGetPid() <= 0 {
            return 2;
        }
        return 0;
    }
} else {
    func PlatformAbiCheck() -> int {
        return 0;
    }
}
