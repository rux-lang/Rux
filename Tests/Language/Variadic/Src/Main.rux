import Rux::Assert;

func Sum(args: float...) -> float {
    var sum: float = 0.0;
    for val in args {
        sum += val;
    }
    return sum;
}

func Calc(args: float...) -> float {
    return Sum(args...);
}

func Main() -> int {
    var res = Sum();
    Assert(res < 0.001, "Expected sum to be 0.0 for no arguments");

    res = Sum(5.0);
    Assert(res - 5.0 < 0.001, "Expected sum to be 5.0 for single argument");

    res = Sum(1.0, 2.0, 3.0);
    Assert(res - 6.0 < 0.001, "Expected sum to be 6.0 for three arguments");

    res = Calc(1.5, 2.5, 3.0, 5.0);
    Assert(res - 12.0 < 0.001, "Expected sum to be 12.0 for four arguments");

    return 0;
}
