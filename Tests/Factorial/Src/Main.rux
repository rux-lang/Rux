import Std::Assert;

// Computes the factorial of a number using an iterative approach
func Factorial(n: uint) -> uint {
    var result: uint = 1;
    for i in 2..=n {
        result *= i as uint;
    }
    return result;
}

func Main() -> int {
    Assert(Factorial(0) == 1, "Factorial of 0 should be 1");
    Assert(Factorial(1) == 1, "Factorial of 1 should be 1");
    Assert(Factorial(2) == 2, "Factorial of 2 should be 2");
    Assert(Factorial(3) == 6, "Factorial of 3 should be 6");
    Assert(Factorial(4) == 24, "Factorial of 4 should be 24");
    Assert(Factorial(5) == 120, "Factorial of 5 should be 120");
    Assert(Factorial(6) == 720, "Factorial of 6 should be 720");
    Assert(Factorial(7) == 5040, "Factorial of 7 should be 5040");
    Assert(Factorial(8) == 40320, "Factorial of 8 should be 40320");
    Assert(Factorial(9) == 362880, "Factorial of 9 should be 362880");
    Assert(Factorial(10) == 3628800, "Factorial of 10 should be 3628800");
    return 0;
}
