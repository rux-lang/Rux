# Rux C++ style — LLVM base, 4-space indent, east const, 120 columns.
# Targets the latest Clang/clang-format (Clang 22+, matching the CI workflows).
Language: Cpp
BasedOnStyle: LLVM

AccessModifierOffset: -4
AlignOperands: AlignAfterOperator
AllowShortBlocksOnASingleLine: Empty
# Keep each case body on its own line below the label.
AllowShortCaseLabelsOnASingleLine: false
# Keep enums expanded one-enumerator-per-line, matching the existing style.
AllowShortEnumsOnASingleLine: false
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: Never
AllowShortLambdasOnASingleLine: All
BinPackArguments: true
BinPackParameters: BinPack
BraceWrapping:
  AfterControlStatement: Never
  BeforeCatch: true
  BeforeElse: true
  BeforeWhile: true
  SplitEmptyFunction: false
  SplitEmptyRecord: false
  SplitEmptyNamespace: false
BreakBeforeBraces: Custom
BreakConstructorInitializers: BeforeComma
BreakTemplateDeclarations: Yes
ColumnLimit: 120
ContinuationIndentWidth: 4
DerivePointerAlignment: false
# Emit/normalize closing-namespace comments (} // namespace Rux::Misc).
FixNamespaceComments: true
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^"Rux/'
    Priority: 1
  - Regex: '^<'
    Priority: 2
  - Regex: '.*'
    Priority: 3
IndentPPDirectives: BeforeHash
IndentWidth: 4
InsertNewlineAtEOF: true
KeepEmptyLines:
  AtEndOfFile: false
  AtStartOfBlock: false
  AtStartOfFile: false
MaxEmptyLinesToKeep: 1
NamespaceIndentation: None
PackConstructorInitializers: Never
PointerAlignment: Right
PPIndentWidth: 4
QualifierAlignment: Left
ReferenceAlignment: Right
SeparateDefinitionBlocks: Always
SortIncludes:
  Enabled: true
  IgnoreCase: false
# Normalize `//comment` to `// comment` (a single leading space).
SpacesInLineCommentPrefix:
  Minimum: 1
  Maximum: 1
Standard: Latest
TabWidth: 4
UseTab: Never
